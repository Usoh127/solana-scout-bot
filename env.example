# ══════════════════════════════════════════════════════════════════════════════
#  Solana Alpha Scout Bot — .env.example
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git. Add it to .gitignore immediately.
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED: Telegram ────────────────────────────────────────────────────────
# Get from @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram numeric user ID.
# Run the bot once, send /start, and your ID will be logged to console.
# Set this to lock the bot to ONLY your account.
TELEGRAM_ALLOWED_USER_ID=123456789

# ── REQUIRED: Solana wallet ───────────────────────────────────────────────────
# Your wallet's private key in base58 format.
# Export from Phantom: Settings → Security → Export Private Key
# ⚠️  NEVER share this key. NEVER commit this file. Use a fresh hot wallet.
# ⚠️  Only put in what you're willing to lose (degen wallet, not your main).
WALLET_PRIVATE_KEY=your_base58_private_key_here

# Solana RPC endpoint.
# Free public endpoint (slow + rate-limited):
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Recommended: Use Helius free tier (100k credits/day) or QuickNode
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── TRADE EXECUTION ───────────────────────────────────────────────────────────
# SOL amount per buy. Start small. This is real money.
BUY_AMOUNT_SOL=0.1

# Slippage tolerance in basis points (100 = 1%, 300 = 3%, 500 = 5%)
# Higher = more likely to fill but worse price. Memecoins often need 3-5%.
SLIPPAGE_BPS=300

# Priority fee in micro-lamports. Helps land txns during Solana congestion.
# 50000 = roughly $0.001 extra per tx at current SOL prices.
PRIORITY_FEE_MICROLAMPORTS=50000

# ── SCOUTING THRESHOLDS (all configurable, no restarts needed) ────────────────
# Minimum liquidity in USD. Tokens below this are NEVER surfaced.
MIN_LIQUIDITY_USD=20000

# Minimum 24h trading volume in USD.
MIN_VOLUME_24H_USD=10000

# Market cap range to scout in (USD)
MIN_MARKET_CAP_USD=50000
MAX_MARKET_CAP_USD=5000000

# Maximum token age in hours since pool creation
MAX_TOKEN_AGE_HOURS=72

# Minimum 1h price change % to qualify (momentum gate)
MIN_PRICE_CHANGE_1H=10.0
MIN_PRICE_CHANGE_6H=20.0

# ── ON-CHAIN SAFETY ───────────────────────────────────────────────────────────
# If top-10 wallets hold more than this % of supply, flag as high risk.
MAX_TOP_10_HOLDER_PCT=40.0

# ── RISK MANAGEMENT ───────────────────────────────────────────────────────────
# Alert if price drops this % from buy price
STOP_LOSS_PCT=15.0

# Alert if pool liquidity drops this % from when you bought
LIQUIDITY_DROP_ALERT_PCT=30.0

# Alert if a single tx sells >= this % of supply (whale dump signal)
LARGE_DUMP_THRESHOLD_PCT=5.0

# VADER sentiment score below this triggers bearish alert (-1.0 to 0.0)
SENTIMENT_BEARISH_THRESHOLD=-0.30

# ── SCANNING INTERVALS ────────────────────────────────────────────────────────
# How often to scan for new tokens (seconds). Don't go below 60s.
SCAN_INTERVAL_SECONDS=120

# How often to check open positions (seconds). 30s is fine.
MONITOR_INTERVAL_SECONDS=30

# Cooldown before re-alerting the same token (hours)
ALERT_COOLDOWN_HOURS=6

# ── OPTIONAL: Twitter API v2 ──────────────────────────────────────────────────
# Sign up at developer.twitter.com → Create Project → Copy Bearer Token
# FREE TIER: 10 search requests / 15 min, 500k tweets / month
# ⚠️  Without this, bot falls back to Nitter scraper (less reliable)
TWITTER_BEARER_TOKEN=

# ── OPTIONAL: NewsAPI ─────────────────────────────────────────────────────────
# Register at newsapi.org → free tier: 100 req/day (non-commercial only)
# ⚠️  PAID TIER required for commercial use (~$449/mo Developer plan)
NEWS_API_KEY=

# ── OPTIONAL: Reddit (PRAW) ───────────────────────────────────────────────────
# Create a "script" app at reddit.com/prefs/apps
# Use: client_id from the app, client_secret from the app
# FREE, no paid tier needed.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SolanaScoutBot/1.0

# ── OPTIONAL: Helius ──────────────────────────────────────────────────────────
# Register at helius.dev — free tier: 100k credits/day
# Used for: better RPC, holder concentration checks, large dump detection
# HIGHLY RECOMMENDED — the public Solana RPC is unreliable
HELIUS_API_KEY=

# ── OPTIONAL: Birdeye ─────────────────────────────────────────────────────────
# Register at birdeye.so — free tier is very limited
# ⚠️  Full token_security endpoint needs PAID Starter plan (~$99/mo)
# Without this, safety checks fall back to Helius + on-chain RPC (still solid)
BIRDEYE_API_KEY=
